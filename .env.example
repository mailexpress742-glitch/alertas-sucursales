DB_TYPE=mariadb
DB_SERVER=servidor_o_ip
DB_NAME=nombre_base
DB_USER=usuario_read_only
DB_PASSWORD=changeme
DB_PORT=3306
DB_DRIVER=pymysql

SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario_smtp
SMTP_PASSWORD=changeme
SMTP_USE_TLS=true
EMAIL_DRY_RUN=true
EMAIL_PREVIEW_DIR=data/email_previews
MAIL_FROM=alertas@example.com
MAIL_TO=operaciones@example.com,finanzas@example.com

ALERT_DAYS_THRESHOLD=7
ALERT_AMOUNT_THRESHOLD=100000
ENABLED_RULES=guide_due_date
GUIDE_DUE_DATE_COLUMN=fecha_vencimiento
GUIDE_LOOKAHEAD_DAYS=7
GUIDE_MAX_ROWS=1000
GUIDE_ONLY_ACTIVE=true
GUIDE_ONLY_UNFINISHED=true
SUCURSAL_RECIPIENTS_FILE=config/sucursal_recipients.json
SUCURSAL_RECIPIENTS_JSON=
SUCURSAL_GROUPS_FILE=config/sucursal_groups.json
SUCURSAL_GROUPS_JSON=
ENVIRONMENT=local
APP_TIMEZONE=America/Argentina/Buenos_Aires

# Opcionales
ALERT_HISTORY_FILE=data/alert_history.json
LOG_FILE=logs/alertas.log
